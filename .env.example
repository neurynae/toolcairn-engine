# ToolCairn Engine — Environment Variables
# Copy to .env for local development

# ── Memgraph ──────────────────────────────────────────────────────────────────
MEMGRAPH_URL=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://toolpilot:toolpilot@localhost:5432/toolpilot

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Embeddings ────────────────────────────────────────────────────────────────
NOMIC_API_KEY=

# ── GitHub Indexer ────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── API Server ────────────────────────────────────────────────────────────────
MCP_SERVER_PORT=3001
MCP_SERVER_HOST=0.0.0.0
ADMIN_SECRET=change-me-in-production
ORIGIN_SECRET=

# ── Deployment ────────────────────────────────────────────────────────────────
TOOLPILOT_MODE=dev
TOOLPILOT_API_URL=https://api.neurynae.com

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
# LOCAL DEV — use test keys (rzp_test_*). No real charges.
#   Get from: https://dashboard.razorpay.com → Settings → API Keys → Test Mode
#
# PRODUCTION — use live keys (rzp_live_*). Real money.
#   Get from: https://dashboard.razorpay.com → Settings → API Keys → Live Mode
#   Requires: completed KYC + business verification
#
# The API auto-detects mode from the key prefix (rzp_test_ vs rzp_live_).
# Create separate plans in Razorpay dashboard for test and live modes.
#
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MONTHLY=plan_...
RAZORPAY_PLAN_QUARTERLY=plan_...
RAZORPAY_PLAN_SEMIANNUAL=plan_...

# ── General ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
