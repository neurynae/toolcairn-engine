{
  "name": "@toolcairn/tools",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./local": {
      "types": "./dist/local.d.ts",
      "default": "./dist/local.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@toolcairn/config": "workspace:*",
    "@toolcairn/core": "workspace:*",
    "@toolcairn/db": "workspace:*",
    "@toolcairn/graph": "workspace:*",
    "@toolcairn/queue": "workspace:*",
    "@toolcairn/search": "workspace:*",
    "@toolcairn/vector": "workspace:*",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@toolcairn/tsconfig": "workspace:*",
    "@types/node": "^22.10.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2"
  }
}
