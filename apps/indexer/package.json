{
  "name": "@toolcairn/indexer",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests",
    "clean": "rimraf dist",
    "index-issues": "tsx src/run-index-issues.ts",
    "migrate-topics": "tsx src/run-migrate-topics.ts"
  },
  "dependencies": {
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^21.0.2",
    "@toolcairn/config": "workspace:*",
    "@toolcairn/core": "workspace:*",
    "@toolcairn/db": "workspace:*",
    "@toolcairn/graph": "workspace:*",
    "@toolcairn/queue": "workspace:*",
    "@toolcairn/vector": "workspace:*",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@toolcairn/tsconfig": "workspace:*",
    "@types/node": "^22.10.7",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4"
  }
}
